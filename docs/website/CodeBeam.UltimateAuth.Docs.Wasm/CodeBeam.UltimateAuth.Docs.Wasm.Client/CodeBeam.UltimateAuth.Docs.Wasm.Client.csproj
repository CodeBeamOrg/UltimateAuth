<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
		<NoDefaultLaunchSettingsFile>true</NoDefaultLaunchSettingsFile>
		<StaticWebAssetProjectMode>Default</StaticWebAssetProjectMode>
		<BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
		<IsPackable>false</IsPackable>
	</PropertyGroup>

	<ItemGroup>
		<PackageReference Include="CodeBeam.MudBlazor.Extensions" Version="9.0.4" />
		<PackageReference Include="CodeBeam.MudBlazor.Extensions.Code" Version="9.0.1" />
		<PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.5" />
		<PackageReference Include="MudBlazor" Version="9.3.0" />
	</ItemGroup>

	<Target Name="BuildDocs" BeforeTargets="Build">
		<Exec WorkingDirectory="$(MSBuildProjectDirectory)" Command="dotnet run --project &quot;$(MSBuildProjectDirectory)\..\..\..\..\src\utilities\CodeBeam.UltimateAuth.DocsBuilder\CodeBeam.UltimateAuth.DocsBuilder.csproj&quot; --solutionDir &quot;$(MSBuildProjectDirectory)\..\..\..\..\&quot;" ConsoleToMSBuild="true" />
	</Target>

	<ProjectExtensions><VisualStudio><UserProperties wwwroot_4docs_4docs-index_1json__JsonSchema="https://www.schemastore.org/aspire-8.0.json" /></VisualStudio></ProjectExtensions>
	
</Project>
